---
interface Props {
  text: string;
  variant?: 'cyan' | 'indigo' | 'success' | 'warning';
  class?: string;
}

const { text, variant = 'cyan', class: className = '' } = Astro.props;

const variantClasses = {
  cyan: 'bg-accent-cyan/10 text-accent-cyan border-accent-cyan/20',
  indigo: 'bg-accent-indigo/10 text-accent-indigo border-accent-indigo/20',
  success: 'bg-success/10 text-success border-success/20',
  warning: 'bg-warning/10 text-warning border-warning/20',
};
---

<span class:list={['inline-flex items-center px-3 py-1 text-xs font-medium rounded-full border', variantClasses[variant], className]}>
  {text}
</span>
