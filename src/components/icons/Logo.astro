---
interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;
---

<a href="/" class:list={['flex items-center gap-2 group', className]}>
  <div class="relative w-9 h-9 flex items-center justify-center rounded-lg bg-accent-cyan/10 border border-accent-cyan/20 group-hover:border-accent-cyan/40 transition-colors">
    <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M4 4h3v12H4V4zm5 0h3v12H9V4zm5 0h3v12h-3V4z" fill="var(--color-accent-cyan)" opacity="0.9"/>
      <circle cx="10" cy="10" r="8.5" stroke="var(--color-accent-cyan)" stroke-width="1" opacity="0.3"/>
    </svg>
  </div>
  <span class="font-heading text-xl font-bold tracking-tight text-white">
    ITOPTS
  </span>
</a>
