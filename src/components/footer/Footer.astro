---
import Logo from '../icons/Logo.astro';
import { navLinks } from '../../data/navigation';
import { siteConfig } from '../../data/site';
---

<footer class="bg-bg-secondary border-t border-border">
  <div class="container-site section-padding">
    <!-- Main footer grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 lg:gap-8">
      <!-- Brand column -->
      <div class="lg:col-span-1">
        <Logo />
        <p class="mt-4 text-sm text-text-muted leading-relaxed max-w-xs">
          Enterprise-grade managed IT, AI automation, and cybersecurity for growing businesses in South Florida.
        </p>
        <div class="flex items-center gap-4 mt-6">
          <a href="#" class="w-9 h-9 flex items-center justify-center rounded-lg bg-bg-card border border-border hover:border-accent-cyan/30 transition-colors" aria-label="LinkedIn">
            <svg width="16" height="16" fill="currentColor" class="text-text-muted" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
          <a href="#" class="w-9 h-9 flex items-center justify-center rounded-lg bg-bg-card border border-border hover:border-accent-cyan/30 transition-colors" aria-label="X (Twitter)">
            <svg width="16" height="16" fill="currentColor" class="text-text-muted" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
          <a href="#" class="w-9 h-9 flex items-center justify-center rounded-lg bg-bg-card border border-border hover:border-accent-cyan/30 transition-colors" aria-label="Facebook">
            <svg width="16" height="16" fill="currentColor" class="text-text-muted" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
        </div>
      </div>

      <!-- Services column -->
      <div>
        <h4 class="text-sm font-semibold text-white uppercase tracking-wider mb-4">Services</h4>
        <ul class="space-y-3">
          <li><a href="/services" class="text-sm text-text-muted hover:text-accent-cyan transition-colors">Managed IT Services</a></li>
          <li><a href="/services" class="text-sm text-text-muted hover:text-accent-cyan transition-colors">AI Automation</a></li>
          <li><a href="/services" class="text-sm text-text-muted hover:text-accent-cyan transition-colors">Cybersecurity</a></li>
          <li><a href="/pricing" class="text-sm text-text-muted hover:text-accent-cyan transition-colors">Pricing</a></li>
        </ul>
      </div>

      <!-- Company column -->
      <div>
        <h4 class="text-sm font-semibold text-white uppercase tracking-wider mb-4">Company</h4>
        <ul class="space-y-3">
          {navLinks.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-text-muted hover:text-accent-cyan transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Newsletter column -->
      <div>
        <h4 class="text-sm font-semibold text-white uppercase tracking-wider mb-4">Stay Updated</h4>
        <p class="text-sm text-text-muted mb-4">Get IT security tips and industry insights delivered monthly.</p>
        <form id="footer-newsletter" class="flex gap-2">
          <input
            type="email"
            placeholder="you@company.com"
            required
            class="flex-1 min-w-0 px-3 py-2 text-sm bg-bg-card border border-border rounded-md text-white placeholder:text-text-muted focus:outline-none focus:border-accent-cyan/50 transition-colors"
          />
          <button
            type="submit"
            class="px-4 py-2 text-sm font-semibold rounded-md bg-accent-cyan text-bg-primary hover:bg-accent-cyan/90 transition-colors shrink-0"
          >
            Join
          </button>
        </form>
        <p id="footer-newsletter-success" class="hidden mt-2 text-success text-xs font-medium">You're subscribed!</p>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-12 pt-8 border-t border-border flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-xs text-text-muted">
        &copy; {new Date().getFullYear()} {siteConfig.name}. All rights reserved.
      </p>
      <p class="text-xs text-text-muted">
        Powered by <a href="https://krescendo.ai" class="text-text-muted hover:text-accent-cyan transition-colors" target="_blank" rel="noopener">Krescendo AI</a>
      </p>
    </div>
  </div>
</footer>

<script>
  const footerForm = document.getElementById('footer-newsletter') as HTMLFormElement;
  const footerSuccess = document.getElementById('footer-newsletter-success');
  footerForm?.addEventListener('submit', (e) => {
    e.preventDefault();
    footerForm.classList.add('hidden');
    if (footerSuccess) footerSuccess.classList.remove('hidden');
  });
</script>
