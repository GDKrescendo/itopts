---
import Button from '../ui/Button.astro';
---

<section class="section-padding" id="home-cta">
  <div class="container-site">
    <div class="relative rounded-2xl border border-border bg-bg-card overflow-hidden p-10 lg:p-16 text-center">
      <!-- Background glow -->
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[500px] h-[300px] bg-accent-cyan/[0.04] rounded-full blur-[100px] pointer-events-none"></div>
      <div class="absolute bottom-0 right-0 w-[300px] h-[200px] bg-accent-indigo/[0.04] rounded-full blur-[80px] pointer-events-none"></div>

      <div class="relative z-10">
        <h2 class="font-heading font-bold max-w-xl mx-auto">Ready to Stop Worrying About IT?</h2>
        <p class="mt-4 text-text-muted text-lg max-w-lg mx-auto">
          Book a free consultation with our team. We'll audit your current setup and show you exactly how ITOPTS can help.
        </p>
        <div class="flex flex-wrap items-center justify-center gap-4 mt-8">
          <Button variant="primary" size="lg" href="/contact">
            Book a Free Consultation
          </Button>
          <Button variant="secondary" size="lg" href="/pricing">
            View Pricing
          </Button>
        </div>
        <p class="mt-6 text-xs text-text-muted">No contracts. No pressure. Just a conversation about your IT needs.</p>
      </div>
    </div>
  </div>
</section>

<script>
  import { fadeUp } from '../../scripts/scroll-animations';
  fadeUp('#home-cta > div > div');
</script>
