---
import Button from '../ui/Button.astro';
import { HeroSpline } from '../sections/HeroSpline';
---

<section class="relative min-h-screen flex items-center overflow-hidden">
  <!-- Spline 3D robot background — fills entire hero -->
  <div class="hero-spline">
    <HeroSpline client:load />
  </div>

  <!-- Particle grid canvas — subtle behind everything -->
  <canvas id="particle-grid" class="absolute inset-0 w-full h-full pointer-events-none opacity-40" aria-hidden="true"></canvas>

  <!-- Subtle ambient glow -->
  <div class="absolute top-1/3 right-1/4 w-[500px] h-[500px] bg-accent-cyan/[0.02] rounded-full blur-[150px] pointer-events-none"></div>

  <!-- Hero content — pointer-events-none so mouse passes through to Spline -->
  <div class="container-site relative z-10 pt-32 pb-20 lg:pt-40 lg:pb-32 pointer-events-none">
    <div class="max-w-2xl">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full border border-accent-cyan/20 bg-accent-cyan/5 mb-8 hero-badge">
        <span class="w-2 h-2 rounded-full bg-accent-cyan animate-pulse"></span>
        <span class="text-xs font-medium text-accent-cyan">Now serving South Florida businesses</span>
      </div>

      <h1 class="font-heading font-bold hero-title">
        Your IT.
        <span class="text-accent-cyan">Protected.</span>
        <br />
        <span class="text-accent-indigo">Automated.</span>
        Optimized.
      </h1>

      <p class="mt-6 text-lg lg:text-xl text-text-muted max-w-xl leading-relaxed hero-subtitle">
        ITOPTS delivers enterprise-grade managed IT, AI automation, and cybersecurity for growing businesses — without the enterprise price tag.
      </p>

      <div class="flex flex-wrap gap-4 mt-10 hero-ctas pointer-events-auto">
        <Button variant="primary" size="lg" href="/contact">
          Get Protected Today
        </Button>
        <Button variant="secondary" size="lg" href="/pricing">
          See Our Plans
        </Button>
      </div>
    </div>

    <!-- Trust bar -->
    <div class="mt-20 pt-8 border-t border-border/50 hero-trust">
      <div class="flex flex-wrap items-center gap-x-8 gap-y-3">
        <div class="flex items-center gap-2 text-sm text-text-muted">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-success"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          SOC 2 Ready
        </div>
        <div class="flex items-center gap-2 text-sm text-text-muted">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-accent-cyan"><circle cx="12" cy="12" r="10"/><polyline points="12,6 12,12 16,14"/></svg>
          24/7 Monitoring
        </div>
        <div class="flex items-center gap-2 text-sm text-text-muted">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-accent-indigo"><path d="M12 2a8 8 0 0 0-8 8c0 6 8 12 8 12s8-6 8-12a8 8 0 0 0-8-8z"/><circle cx="12" cy="10" r="3"/></svg>
          AI-Powered Response
        </div>
        <div class="flex items-center gap-2 text-sm text-text-muted">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-warning"><polygon points="12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26"/></svg>
          South Florida's MSP of Choice
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import { initParticleGrid } from '../../scripts/particle-grid';
  import { gsap } from '../../scripts/gsap-init';

  const canvas = document.getElementById('particle-grid') as HTMLCanvasElement;
  if (canvas) initParticleGrid(canvas);

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (!prefersReducedMotion) {
    const tl = gsap.timeline({ defaults: { ease: 'power3.out' } });
    tl.from('.hero-badge', { opacity: 0, y: 15, duration: 0.5 })
      .from('.hero-title', { opacity: 0, y: 30, duration: 0.9 }, '-=0.2')
      .from('.hero-subtitle', { opacity: 0, y: 20, duration: 0.7 }, '-=0.4')
      .from('.hero-ctas', { opacity: 0, y: 20, duration: 0.6 }, '-=0.3')
      .from('.hero-trust', { opacity: 0, y: 15, duration: 0.6 }, '-=0.2');
  }
</script>
