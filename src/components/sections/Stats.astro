---
import IconWrapper from '../icons/IconWrapper';
import { stats } from '../../data/stats';
---

<section class="section-padding" id="stats-section">
  <div class="container-site">
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-6 stats-grid">
      {stats.map((stat) => (
        <div class="relative bg-bg-card rounded-[var(--radius-card)] border border-border p-6 text-center group hover:border-accent-cyan/20 transition-all duration-300">
          <div class="w-10 h-10 flex items-center justify-center rounded-lg bg-accent-cyan/10 mx-auto mb-4">
            <IconWrapper client:load name={stat.icon} size={20} className="text-[var(--color-accent-cyan)]" />
          </div>
          <div
            class="text-3xl lg:text-4xl font-heading font-bold text-white stat-counter"
            data-target={stat.value}
            data-suffix={stat.suffix}
            data-prefix={stat.prefix}
          >
            {stat.prefix}0{stat.suffix}
          </div>
          <p class="text-sm text-text-muted mt-2">{stat.label}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  import { counterAnimation, staggerCards } from '../../scripts/scroll-animations';

  staggerCards('#stats-section .stats-grid', ':scope > div');

  document.querySelectorAll('.stat-counter').forEach((el) => {
    counterAnimation(el as HTMLElement);
  });
</script>
