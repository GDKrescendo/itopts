---
import PageLayout from '../layouts/PageLayout.astro';
import SectionHeading from '../components/ui/SectionHeading.astro';
import Badge from '../components/ui/Badge.astro';
import Button from '../components/ui/Button.astro';
import Card from '../components/ui/Card.astro';
import IconWrapper from '../components/icons/IconWrapper';
import { pricingTiers, addOns } from '../data/pricing';
---

<PageLayout title="Pricing" description="Transparent pricing for managed IT, AI automation, and cybersecurity services. No hidden fees, no long-term contracts.">
  <!-- Hero -->
  <section class="pt-32 lg:pt-40 pb-16 lg:pb-20 bg-bg-primary">
    <div class="container-site text-center">
      <span class="inline-block text-xs font-semibold uppercase tracking-[0.15em] text-accent-cyan mb-3">Pricing</span>
      <h1 class="font-heading font-bold max-w-2xl mx-auto">Simple, Transparent <span class="text-accent-cyan">Pricing</span></h1>
      <p class="mt-6 text-lg text-text-muted max-w-xl mx-auto leading-relaxed">
        No hidden fees. No long-term contracts. Choose the plan that fits your business today and scale as you grow.
      </p>
    </div>
  </section>

  <!-- Pricing Tiers -->
  <section class="section-padding bg-bg-secondary" id="pricing-tiers">
    <div class="container-site">
      <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-6 pricing-grid">
        {pricingTiers.map((tier) => (
          <div class:list={[
            'relative bg-bg-card rounded-[var(--radius-card)] border p-6 flex flex-col transition-all duration-300',
            tier.popular
              ? 'border-accent-cyan/40 shadow-[0_0_30px_rgba(0,212,255,0.08)]'
              : 'border-border hover:border-border/80',
          ]}>
            {tier.popular && (
              <div class="absolute -top-3 left-1/2 -translate-x-1/2">
                <Badge text="Most Popular" variant="cyan" />
              </div>
            )}

            <div class="mb-6">
              <h3 class="font-heading font-bold text-xl text-white">{tier.name}</h3>
              <div class="mt-3 flex items-baseline gap-1">
                <span class="text-4xl font-heading font-bold text-white">{tier.price}</span>
                {tier.period && <span class="text-text-muted text-sm">{tier.period}</span>}
              </div>
              <p class="mt-2 text-sm text-text-muted">{tier.description}</p>
            </div>

            <div class="flex-1">
              <ul class="space-y-3">
                {tier.features.map((f) => (
                  <li class="flex items-start gap-2.5">
                    {f.included ? (
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-success)" stroke-width="2.5" class="shrink-0 mt-0.5"><polyline points="20,6 9,17 4,12"/></svg>
                    ) : (
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-text-muted)" stroke-width="2" class="shrink-0 mt-0.5 opacity-40"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                    )}
                    <span class:list={['text-sm', f.included ? 'text-text-body' : 'text-text-muted/50']}>{f.text}</span>
                  </li>
                ))}
              </ul>
            </div>

            <div class="mt-6 pt-6 border-t border-border">
              <p class="text-xs text-text-muted mb-3">Best for: {tier.bestFor}</p>
              <Button
                variant={tier.popular ? 'primary' : 'secondary'}
                size="md"
                href="/contact"
                class="w-full"
              >
                {tier.cta}
              </Button>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Add-ons -->
  <section class="section-padding bg-bg-primary" id="add-ons">
    <div class="container-site">
      <SectionHeading
        overline="Add-Ons"
        title="Enhance Your Plan"
        description="Customize your package with these powerful add-ons."
      />

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mt-14 addons-grid">
        {addOns.map((addon) => (
          <Card borderAccent="indigo">
            <div class="w-10 h-10 flex items-center justify-center rounded-lg bg-accent-indigo/10 mb-4">
              <IconWrapper client:load name={addon.icon} size={20} className="text-[var(--color-accent-indigo)]" />
            </div>
            <h3 class="font-heading font-semibold text-base text-white mb-1">{addon.title}</h3>
            <p class="text-accent-cyan font-heading font-semibold text-sm mb-2">{addon.price}</p>
            <p class="text-text-muted text-sm leading-relaxed">{addon.description}</p>
          </Card>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ / Trust -->
  <section class="section-padding bg-bg-secondary">
    <div class="container-site text-center">
      <h2 class="font-heading font-bold">Not Sure Which Plan Is Right?</h2>
      <p class="mt-4 text-text-muted text-lg max-w-lg mx-auto">
        Our team will help you find the perfect fit. Get a free IT assessment and personalized recommendation.
      </p>
      <div class="flex flex-wrap items-center justify-center gap-4 mt-8">
        <Button variant="primary" size="lg" href="/contact">Talk to an Expert</Button>
      </div>
      <div class="flex flex-wrap items-center justify-center gap-6 mt-8">
        <span class="flex items-center gap-2 text-sm text-text-muted">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-success)" stroke-width="2"><polyline points="20,6 9,17 4,12"/></svg>
          No long-term contracts
        </span>
        <span class="flex items-center gap-2 text-sm text-text-muted">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-success)" stroke-width="2"><polyline points="20,6 9,17 4,12"/></svg>
          Cancel anytime
        </span>
        <span class="flex items-center gap-2 text-sm text-text-muted">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-success)" stroke-width="2"><polyline points="20,6 9,17 4,12"/></svg>
          Free onboarding
        </span>
      </div>
    </div>
  </section>
</PageLayout>

<script>
  import { staggerCards } from '../scripts/scroll-animations';
  staggerCards('#pricing-tiers .pricing-grid', ':scope > div');
  staggerCards('#add-ons .addons-grid', ':scope > div');
</script>
