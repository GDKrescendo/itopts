---
import PageLayout from '../layouts/PageLayout.astro';
import Card from '../components/ui/Card.astro';
import Button from '../components/ui/Button.astro';
import Input from '../components/ui/Input.astro';
import Textarea from '../components/ui/Textarea.astro';
import Select from '../components/ui/Select.astro';
import IconWrapper from '../components/icons/IconWrapper';
import { siteConfig } from '../data/site';

const employeeOptions = [
  { value: '1-10', label: '1–10 employees' },
  { value: '11-25', label: '11–25 employees' },
  { value: '26-50', label: '26–50 employees' },
  { value: '51-100', label: '51–100 employees' },
  { value: '100+', label: '100+ employees' },
];
---

<PageLayout title="Contact" description="Get in touch with ITOPTS for a free IT consultation. We respond within 2 business hours.">
  <!-- Hero -->
  <section class="pt-32 lg:pt-40 pb-16 lg:pb-20 bg-bg-primary">
    <div class="container-site">
      <div class="max-w-3xl">
        <span class="inline-block text-xs font-semibold uppercase tracking-[0.15em] text-accent-cyan mb-3">Contact Us</span>
        <h1 class="font-heading font-bold">Let's Talk About Your <span class="text-accent-cyan">IT Needs</span></h1>
        <p class="mt-6 text-lg text-text-muted leading-relaxed">
          Whether you're looking for managed IT support, AI automation, or cybersecurity — we're here to help. Fill out the form and our team will get back to you within 2 business hours.
        </p>
      </div>
    </div>
  </section>

  <!-- Contact Form + Info -->
  <section class="section-padding bg-bg-secondary">
    <div class="container-site">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12">
        <!-- Form -->
        <div class="lg:col-span-3">
          <Card hover={false} borderAccent="none" class="p-8">
            <h2 class="font-heading font-bold text-xl text-white mb-6">Send Us a Message</h2>
            <form id="contact-form" class="space-y-5">
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                <Input label="Full Name" name="name" placeholder="John Smith" required />
                <Input label="Company" name="company" placeholder="Acme Corp" />
              </div>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                <Input label="Email" name="email" type="email" placeholder="john@company.com" required />
                <Input label="Phone" name="phone" type="tel" placeholder="(555) 123-4567" />
              </div>
              <Select label="Company Size" name="employees" options={employeeOptions} />
              <Textarea label="How Can We Help?" name="message" rows={4} placeholder="Tell us about your IT challenges, goals, or questions..." required />
              <Button variant="primary" size="lg" type="submit" class="w-full sm:w-auto">
                Send Message
              </Button>
              <div id="contact-success" class="hidden mt-4 p-4 rounded-lg bg-success/10 border border-success/20">
                <p class="text-success text-sm font-medium">Thanks for reaching out! We'll respond within 2 business hours.</p>
              </div>
            </form>
          </Card>
        </div>

        <!-- Contact Info -->
        <div class="lg:col-span-2 space-y-6">
          <!-- Book a call -->
          <Card borderAccent="cyan">
            <div class="flex items-center gap-3 mb-4">
              <div class="w-10 h-10 flex items-center justify-center rounded-lg bg-accent-cyan/10">
                <IconWrapper client:load name="calendar" size={20} className="text-[var(--color-accent-cyan)]" />
              </div>
              <div>
                <h3 class="font-heading font-semibold text-white">Prefer to Talk?</h3>
                <p class="text-xs text-text-muted">Book a free 30-minute consultation</p>
              </div>
            </div>
            <Button variant="secondary" size="md" href="tel:5612894687" class="w-full">
              Call (561) 289-4687
            </Button>
          </Card>

          <!-- Contact details -->
          <Card borderAccent="none" hover={false}>
            <h3 class="font-heading font-semibold text-white mb-5">Contact Information</h3>
            <div class="space-y-4">
              <div class="flex items-start gap-3">
                <IconWrapper client:load name="mail" size={18} className="text-[var(--color-accent-cyan)] mt-0.5" />
                <div>
                  <p class="text-xs text-text-muted mb-0.5">Email</p>
                  <a href={`mailto:${siteConfig.email}`} class="text-sm text-white hover:text-accent-cyan transition-colors">{siteConfig.email}</a>
                </div>
              </div>
              <div class="flex items-start gap-3">
                <IconWrapper client:load name="phone" size={18} className="text-[var(--color-accent-cyan)] mt-0.5" />
                <div>
                  <p class="text-xs text-text-muted mb-0.5">Phone</p>
                  <a href={`tel:${siteConfig.phone}`} class="text-sm text-white hover:text-accent-cyan transition-colors">{siteConfig.phone}</a>
                </div>
              </div>
              <div class="flex items-start gap-3">
                <IconWrapper client:load name="map-pin" size={18} className="text-[var(--color-accent-cyan)] mt-0.5" />
                <div>
                  <p class="text-xs text-text-muted mb-0.5">Location</p>
                  <p class="text-sm text-white">{siteConfig.location}</p>
                </div>
              </div>
              <div class="flex items-start gap-3">
                <IconWrapper client:load name="clock" size={18} className="text-[var(--color-accent-cyan)] mt-0.5" />
                <div>
                  <p class="text-xs text-text-muted mb-0.5">Response Time</p>
                  <p class="text-sm text-white">Within 2 business hours</p>
                </div>
              </div>
            </div>
          </Card>

          <!-- Trust signals -->
          <div class="p-5 rounded-[var(--radius-card)] border border-border bg-bg-card/50">
            <div class="flex items-center gap-2 mb-3">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-success)" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              <span class="text-sm font-medium text-white">Your data is secure</span>
            </div>
            <p class="text-xs text-text-muted leading-relaxed">
              We never share your information with third parties. All communications are encrypted and handled in accordance with our privacy policy.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>
</PageLayout>

<script>
  import { fadeUp } from '../scripts/scroll-animations';
  fadeUp('.lg\\:col-span-3');
  fadeUp('.lg\\:col-span-2');

  const form = document.getElementById('contact-form') as HTMLFormElement;
  const success = document.getElementById('contact-success');
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    form.querySelectorAll('input, textarea, select, button[type="submit"]').forEach((el) => {
      (el as HTMLInputElement).disabled = true;
    });
    if (success) {
      success.classList.remove('hidden');
      success.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }
  });
</script>
