---
import PageLayout from '../layouts/PageLayout.astro';
import Button from '../components/ui/Button.astro';
---

<PageLayout title="Page Not Found" description="The page you're looking for doesn't exist.">
  <section class="min-h-[80vh] flex items-center justify-center">
    <div class="container-site text-center">
      <div class="inline-flex items-center justify-center w-20 h-20 rounded-full bg-accent-cyan/10 border border-accent-cyan/20 mb-8">
        <span class="text-3xl font-heading font-bold text-accent-cyan">404</span>
      </div>
      <h1 class="font-heading font-bold text-4xl lg:text-5xl">Page Not Found</h1>
      <p class="mt-4 text-text-muted text-lg max-w-md mx-auto">
        The page you're looking for doesn't exist or has been moved. Let's get you back on track.
      </p>
      <div class="flex flex-wrap items-center justify-center gap-4 mt-8">
        <Button variant="primary" size="lg" href="/">Back to Home</Button>
        <Button variant="secondary" size="lg" href="/contact">Contact Us</Button>
      </div>
    </div>
  </section>
</PageLayout>
