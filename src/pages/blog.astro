---
import PageLayout from '../layouts/PageLayout.astro';
import Card from '../components/ui/Card.astro';
import Badge from '../components/ui/Badge.astro';
import { blogPosts } from '../data/blog-posts';
---

<PageLayout title="Blog" description="IT security tips, AI automation insights, and managed services best practices from the ITOPTS team.">
  <!-- Hero -->
  <section class="pt-32 lg:pt-40 pb-16 lg:pb-20 bg-bg-primary">
    <div class="container-site">
      <div class="max-w-3xl">
        <span class="inline-block text-xs font-semibold uppercase tracking-[0.15em] text-accent-cyan mb-3">Resources</span>
        <h1 class="font-heading font-bold">Insights & <span class="text-accent-cyan">Resources</span></h1>
        <p class="mt-6 text-lg text-text-muted leading-relaxed">
          Stay ahead of the curve with expert insights on cybersecurity, AI automation, and managed IT best practices.
        </p>
      </div>
    </div>
  </section>

  <!-- Blog Posts -->
  <section class="section-padding bg-bg-secondary" id="blog-posts">
    <div class="container-site">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 blog-grid">
        {blogPosts.map((post) => (
          <div class="group block cursor-default">
            <Card borderAccent="cyan" class="h-full flex flex-col">
              <!-- Thumbnail placeholder -->
              <div class="aspect-video rounded-lg bg-bg-primary border border-border mb-5 flex items-center justify-center overflow-hidden">
                <div class="text-center">
                  <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent-cyan)" stroke-width="1" class="mx-auto opacity-30" aria-hidden="true">
                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14,2 14,8 20,8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10,9 9,9 8,9"/>
                  </svg>
                </div>
              </div>

              <div class="flex items-center gap-3 mb-3">
                <Badge
                  text={post.category}
                  variant={post.category === 'Cybersecurity' ? 'cyan' : post.category === 'AI Automation' ? 'indigo' : 'success'}
                />
                <span class="text-xs text-text-muted">{post.readTime}</span>
              </div>

              <h3 class="font-heading font-semibold text-lg text-white mb-3 group-hover:text-accent-cyan transition-colors">
                {post.title}
              </h3>
              <p class="text-text-muted text-sm leading-relaxed flex-1">{post.excerpt}</p>

              <div class="mt-5 pt-4 border-t border-border flex items-center justify-between">
                <span class="text-xs text-text-muted">{post.date}</span>
                <span class="text-xs font-medium text-accent-cyan inline-flex items-center gap-1">
                  Coming Soon
                </span>
              </div>
            </Card>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Newsletter CTA -->
  <section class="section-padding bg-bg-primary">
    <div class="container-site text-center">
      <h2 class="font-heading font-bold">Get IT Insights in Your Inbox</h2>
      <p class="mt-4 text-text-muted text-lg max-w-lg mx-auto">
        Subscribe to our monthly newsletter for security tips, automation ideas, and industry updates.
      </p>
      <form id="blog-newsletter" class="mt-8 flex flex-col sm:flex-row gap-3 max-w-md mx-auto">
        <input
          type="email"
          placeholder="you@company.com"
          required
          class="flex-1 px-4 py-3 text-sm bg-bg-card border border-border rounded-md text-white placeholder:text-text-muted focus:outline-none focus:border-accent-cyan/50 transition-colors"
        />
        <button
          type="submit"
          class="px-6 py-3 text-sm font-semibold rounded-md bg-accent-cyan text-bg-primary hover:bg-accent-cyan/90 transition-colors shrink-0"
        >
          Subscribe
        </button>
      </form>
      <p id="blog-newsletter-success" class="hidden mt-4 text-success text-sm font-medium">You're subscribed! Check your inbox soon.</p>
    </div>
  </section>
</PageLayout>

<script>
  import { staggerCards } from '../scripts/scroll-animations';
  staggerCards('#blog-posts .blog-grid', ':scope > div');

  const blogForm = document.getElementById('blog-newsletter') as HTMLFormElement;
  const blogSuccess = document.getElementById('blog-newsletter-success');
  blogForm?.addEventListener('submit', (e) => {
    e.preventDefault();
    blogForm.classList.add('hidden');
    if (blogSuccess) blogSuccess.classList.remove('hidden');
  });
</script>
