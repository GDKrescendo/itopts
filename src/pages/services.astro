---
import PageLayout from '../layouts/PageLayout.astro';
import SectionHeading from '../components/ui/SectionHeading.astro';
import Card from '../components/ui/Card.astro';
import Button from '../components/ui/Button.astro';
import IconWrapper from '../components/icons/IconWrapper';
import { serviceCategories, managedITTiers } from '../data/services';
---

<PageLayout title="Services" description="Managed IT Services, AI Automation, and Cybersecurity solutions for growing businesses in South Florida.">
  <!-- Hero -->
  <section class="pt-32 lg:pt-40 pb-16 lg:pb-20 bg-bg-primary">
    <div class="container-site">
      <div class="max-w-3xl">
        <span class="inline-block text-xs font-semibold uppercase tracking-[0.15em] text-accent-cyan mb-3">Our Services</span>
        <h1 class="font-heading font-bold">Everything Your Business Needs to <span class="text-accent-cyan">Thrive</span></h1>
        <p class="mt-6 text-lg text-text-muted leading-relaxed">
          From 24/7 IT support to cutting-edge AI automation and bulletproof cybersecurity — we deliver complete technology solutions under one roof.
        </p>
      </div>
    </div>
  </section>

  <!-- Service Categories -->
  {serviceCategories.map((category, catIdx) => (
    <section
      id={category.id}
      class:list={['section-padding', catIdx % 2 === 0 ? 'bg-bg-secondary' : 'bg-bg-primary']}
    >
      <div class="container-site">
        <div class="flex items-start gap-4 mb-4">
          <div class="w-12 h-12 flex items-center justify-center rounded-lg bg-accent-cyan/10 shrink-0">
            <IconWrapper client:load name={category.icon} size={24} className="text-[var(--color-accent-cyan)]" />
          </div>
          <div>
            <span class="text-xs font-semibold uppercase tracking-[0.15em] text-accent-cyan">{category.tagline}</span>
            <h2 class="font-heading font-bold mt-1">{category.title}</h2>
          </div>
        </div>
        <p class="text-text-muted text-lg leading-relaxed max-w-3xl mb-10">{category.description}</p>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 service-items-grid">
          {category.items.map((item) => (
            <Card borderAccent={catIdx === 1 ? 'indigo' : 'cyan'}>
              <div class="w-10 h-10 flex items-center justify-center rounded-lg bg-accent-cyan/10 mb-4">
                <IconWrapper client:load name={item.icon} size={20} className={catIdx === 1 ? 'text-[var(--color-accent-indigo)]' : 'text-[var(--color-accent-cyan)]'} />
              </div>
              <h3 class="font-heading font-semibold text-lg text-white mb-2">{item.title}</h3>
              <p class="text-text-muted text-sm leading-relaxed">{item.description}</p>
            </Card>
          ))}
        </div>

        {/* Managed IT tiers */}
        {category.id === 'managed-it' && (
          <div class="mt-10 p-6 bg-bg-card rounded-[var(--radius-card)] border border-border">
            <h3 class="font-heading font-semibold text-lg text-white mb-4">Support Tiers</h3>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
              {managedITTiers.map((tier) => (
                <div class="p-4 rounded-lg border border-border bg-bg-primary/50">
                  <p class="text-sm font-medium text-white">{tier.hours}</p>
                  <p class="text-accent-cyan font-heading font-bold text-lg mt-1">{tier.price}</p>
                </div>
              ))}
            </div>
          </div>
        )}

        <div class="mt-8 flex items-center gap-4">
          <p class="text-sm text-text-muted">{category.pricing}</p>
          <Button variant="secondary" size="sm" href="/contact">Get a Quote</Button>
        </div>
      </div>
    </section>
  ))}

  <!-- Bottom CTA -->
  <section class="section-padding bg-bg-primary">
    <div class="container-site text-center">
      <h2 class="font-heading font-bold">Need a Custom Solution?</h2>
      <p class="mt-4 text-text-muted text-lg max-w-lg mx-auto">
        Every business is different. Let's build a package tailored to your exact needs.
      </p>
      <div class="mt-8">
        <Button variant="primary" size="lg" href="/contact">Schedule a Free Consultation</Button>
      </div>
    </div>
  </section>
</PageLayout>

<script>
  import { staggerCards } from '../scripts/scroll-animations';
  document.querySelectorAll('.service-items-grid').forEach((grid, i) => {
    staggerCards(`.service-items-grid:nth-of-type(${i + 1})`, ':scope > div');
  });
</script>
